APP_NAME=AI Site Analyst
APP_ENV=production
DEBUG=false
SQL_ECHO=false
APP_BASE_URL=https://translator-word.com
LOCAL_APP_BASE_URL=http://localhost:8001

DEMO_SITE_ID=

POSTGRES_DB=ai_site_analyst
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/ai_site_analyst

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-lite-latest,gemini-2.0-flash-lite,gemini-flash-latest

ADMIN_DASHBOARD_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD
ADMIN_SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
ADMIN_API_KEY=CHANGE_ME_LONG_RANDOM_API_KEY
ADMIN_SESSION_TTL_SECONDS=86400
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

ENABLE_DEMO_ENDPOINTS=false
ALLOWED_ORIGINS=https://translator-word.com
TRACKER_RATE_LIMIT_PER_MINUTE=120

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://translator-word.com/api/gsc/oauth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_AUTH_REDIRECT_URI=https://translator-word.com/auth/google/callback
GOOGLE_AUTH_SCOPES=openid,email,profile

PAGESPEED_API_KEY=

TOKEN_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

REQUIRE_EXTERNAL_INTEGRATIONS=false
