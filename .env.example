# Local development defaults.
APP_NAME=AI Site Analyst
APP_ENV=local
DEBUG=true
SQL_ECHO=false
APP_BASE_URL=http://localhost:8000

# Optional: set this to make /demo always use one site without ?site_id=...
DEMO_SITE_ID=

DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/ai_site_analyst

POSTGRES_DB=ai_site_analyst
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional local AI integration. Empty value enables fallback analysis.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Local-only admin credentials. Change these after copying to .env.
ADMIN_DASHBOARD_PASSWORD=local_admin_password_change_me
ADMIN_SESSION_SECRET=local_session_secret_change_me

# Optional for scripts/curl that need access to private admin API endpoints.
ADMIN_API_KEY=local_admin_api_key_change_me
ADMIN_SESSION_TTL_SECONDS=86400
ADMIN_LOGIN_RATE_LIMIT_PER_MINUTE=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# Local demo helpers. Production must set ENABLE_DEMO_ENDPOINTS=false.
ENABLE_DEMO_ENDPOINTS=true
ALLOWED_ORIGINS=*
TRACKER_RATE_LIMIT_PER_MINUTE=120

# Optional Google Search Console OAuth integration.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/gsc/oauth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/webmasters.readonly
GOOGLE_AUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
GOOGLE_AUTH_SCOPES=openid,email,profile
PAGESPEED_API_KEY=

# Production required for encrypting Google OAuth tokens.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Production email for password reset links.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Set true on the server if Google, PageSpeed and Gemini must all be configured before startup.
REQUIRE_EXTERNAL_INTEGRATIONS=false
